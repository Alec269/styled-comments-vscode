{
   "name": "styled-comments",
   "displayName": "Styled Comments",
   "description": "Highlight comments in different colors within various languages with special symbols - `, ~, !, @, #, $, %, ^, &, *, ?, TODO: ",
   "version": "2.5.0",
   "publisher": "Alec269",
   "author": {
      "name": "Nomayer Alam",
      "email": "alac269b@gmail.com"
   },
   "license": "MIT",
   "repository": {
      "type": "git",
      "url": "https://github.com/Alec269/styled-comments-vscode.git"
   },
   "bugs": {
      "url": "https://github.com/Alec269/styled-comments-vscode/issues"
   },
   "homepage": "https://github.com/Alec269/styled-comments-vscode#readme",
   "keywords": [
      "comments",
      "highlighting",
      "syntax",
      "colors",
      "todo",
      "productivity",
      "c++",
      "js",
      "ts",
      "jsx",
      "tsx"
   ],
   "categories": [
      "Themes"
   ],
   "engines": {
      "vscode": "^1.74.0"
   },
   "activationEvents": [
      "onStartupFinished"
   ],
   "main": "./out/extension.js",
   "icon": "images/icon.png",
   "contributes": {
      "commands": [
         {
            "command": "styledComments.enable",
            "title": "Enable Styled Comments"
         },
         {
            "command": "styledComments.disable",
            "title": "Disable Styled Comments"
         }
      ],
      "configuration": {
         "title": "Styled Comments",
         "properties": {
            "styledComments.enabled": {
               "type": "boolean",
               "default": true,
               "description": "Enable styled comment highlighting"
            }
         }
      }
   },
   "scripts": {
      "vscode:prepublish": "npm run compile",
      "compile": "tsc -p ./",
      "watch": "tsc -watch -p ./"
   },
   "devDependencies": {
      "@types/vscode": "^1.74.0",
      "@types/node": "16.x",
      "typescript": "^4.9.4"
   }
}