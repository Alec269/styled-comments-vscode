{
  "name": "styled-comments",
  "displayName": "Styled Comments",
  "description": "Highlight comments with special symbols in different colors - ?, *, !, @, TODO:, $, &, #",
  "version": "1.0.0",
  "publisher": "Alec269",
  "author": {
    "name": "Nomayer Alam",
    "email": "alac269b@gmail.com"
  },
  "license": "ARR",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "comments",
    "highlighting",
    "syntax",
    "colors",
    "todo",
    "productivity"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "styledComments.enable",
        "title": "Enable Styled Comments"
      },
      {
        "command": "styledComments.disable",
        "title": "Disable Styled Comments"
      }
    ],
    "configuration": {
      "title": "Styled Comments",
      "properties": {
        "styledComments.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable styled comment highlighting"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "typescript": "^4.9.4"
  }
}
