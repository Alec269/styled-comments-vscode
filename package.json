{
  "name": "styled-comments",
  "displayName": "Styled Comments",
  "description": "Highlight comments with special symbols in different colors",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "styledComments.enable",
        "title": "Enable Styled Comments"
      },
      {
        "command": "styledComments.disable",
        "title": "Disable Styled Comments"
      }
    ],
    "configuration": {
      "title": "Styled Comments",
      "properties": {
        "styledComments.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable styled comment highlighting"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.102.0",
    "typescript": "^4.9.5"
  }
}
